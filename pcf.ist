(* Now: do all this again with filters defined incorrectly. *)


(* Forces snd s eagerly. *)
define /filters' {a} p/
/
  ffix (fn filtf s .
          let next filt = filtf in
          bindev t = snd s
          in
            if p (fst s) then
              now (cons 
                     (fst s) 
                     (later (filt t)))
            else
              later (filt t))
//
  intersect i . forall (a : U i) . (a -> bool) -> stream a -> ev (stream a)
/;

inference.
unfold /filters'/.
typecheck.
qed ();



reductions
/
  filters' a p (cons _ h te) -->
    later
      (bindev t = te
       in
         if p h then 
           now (cons a 
                  h
                  (later (filters' a p t)))
         else
           later (filters' a p t)) ;

  unfolding filters'
  unrolling ffix
/;



lemma "Foralls_filters'"
/
  forall i (a : U i) (p : a -> bool) (s : stream a) .
    bindevt s' = filters' p s
    in
      Foralls (fn x . istrue (p x)) s'
/;

inference.
intro /i a p/.
apply /ffix/.
intro /[IH] s/.
unrollTypeUniv /stream with i in s/.
destruct /s/ /h [te]/.
fold /cons h te/.
reduce //.
split.
rewrite /-> bindevt_assoc/.
reduce //.
apply /bindevt_simple/.
reduce //.
intro /t/.
boolCase /p h/ /Hp/ >> auto.
qed ();



lemma "Foralls_filters'_preserve"
/
  forall i (a : U i) (p : a -> bool) (Q : a -> U i) (s : stream a) .
    Foralls Q s
    -> bindevt s' = filters' p s
       in
         Foralls Q s'
/;

inference.
intro /i a p Q/.
apply /ffix/.
intro /[IH] s Hs/.
unrollTypeUniv /stream with i in s/.
destruct /s/ /h [te]/.
fold /cons h te in Hs in concl/.
reduce /Hs concl/.
destruct /Hs/ /Hh [Hte]/.
split.
rewrite /-> bindevt_assoc/.
reduce //.
witness /bindevt_map _# 5 __ Hte/.
reduce //.
intro /t Ht/.
boolCase /p h/ /Hp/ >> auto.
qed ();



define /sieve' {a} d/
/
  ffix (fn sief s .
          let next sie = sief
          in
            cons 
              (fst s)
              (bindev t = snd s in
               bindev t' = filters' (d (fst s)) t
               in
                 later (now (sie t'))))
//
  intersect i . forall (a : U i) . (a -> a -> bool) -> stream a -> stream a
/;

inference.
unfold /sieve'/.
typecheck.
qed ();



reductions
/
  sieve' a d (cons _ h te) -->
    cons a
      h
      (later
         (bindev t = te in
          bindev t' = filters' a (d h) t 
          in 
            later (now (sieve' a d t')))) ;

  unfolding sieve'
  unrolling ffix
/;



lemma "sieve'_preserve"
/
  forall i (a : U i) (P : a -> U i) (d : a -> a -> bool) (s : stream a) .
    Foralls P s
    -> Foralls P (sieve' d s)
/;

inference.
intro /i a P d/.
apply /ffix/.
intro /[IH] s Hs/.
unrollTypeUniv /stream with i in s/.
destruct /s/ /h [t]/.
fold /cons h t in Hs in concl/.
reduce /Hs concl/.
destruct /Hs/ /Hh [Ht]/.
split >> auto.
split.
split.
rewrite /-> bindevt_assoc/.
reduce //.
witness /bindevt_map _# 5 __ Ht/.
reduce //.
intro /s Hs/.
rewrite /-> bindevt_assoc/.
reduce //.
so /Foralls_filters'_preserve _ _ (d h) _ _ Hs/ /H/.
witness /bindevt_map _# 5 __ H/.
reduce //.
auto.
qed ();



