Subst : Ctx → Ctx → Set
  Subst Γ Δ = ∀ {A} → Γ ∋ A → Exp Δ A
  
  Rename : Ctx → Ctx → Set
  Rename Γ Δ = ∀ {A} → Γ ∋ A → Δ ∋ A
  
  extend-var : Rename Γ Δ → Rename (Γ # A) (Δ # A)
  extend-var ρ Z      =  Z
  extend-var ρ (S x)  =  S (ρ x)

  lift : Rename Γ (Γ # A)
  lift Z = S Z
  lift (S x) = S (lift x)
  
  rename : Rename Γ Δ → Exp Γ B → Exp Δ B
  rename ρ (` x)         = ` (ρ x)
  rename ρ yes           = yes
  rename ρ no            = no
  rename ρ triv          = triv
  rename ρ (pair M₁ M₂)  = pair (rename ρ M₁) (rename ρ M₂)
  rename ρ (fst M)       = fst (rename ρ M)
  rename ρ (snd M)       = snd (rename ρ M)
  rename ρ (lam M)       = lam (rename (extend-var ρ) M)
  rename ρ (app M M₁)    = app (rename ρ M) (rename ρ M₁)
  rename ρ zero          = zero
  rename ρ (suc M)       = suc (rename ρ M)
  rename ρ (rec M₀ M₁ M) = rec (rename ρ M₀) (rename (extend-var ρ) M₁) (rename ρ M)
  
  weaken : Subst Γ Δ → Subst (Γ # A) (Δ # A)
  weaken γ Z     = ` Z
  weaken γ (S x) = rename S (γ x)
  
  subst : Subst Γ Δ → Exp Γ A → Exp Δ A
  subst γ (` x)         = γ x
  subst γ yes           = yes
  subst γ no            = no
  subst γ triv          = triv
  subst γ (pair M₁ M₂)  = pair (subst γ M₁) (subst γ M₂)
  subst γ (fst M)       = fst (subst γ M)
  subst γ (snd M)       = snd (subst γ M)
  subst γ (lam M)       = lam (subst (weaken γ) M)
  subst γ (app M M₁)    = app (subst γ M) (subst γ M₁)
  subst γ zero          = zero
  subst γ (suc M)       = suc (subst γ M)
  subst γ (rec M₀ M₁ M) = rec (subst γ M₀) (subst (weaken γ) M₁) (subst γ M)
  
  extend : Exp Δ A → Subst Γ Δ → Subst (Γ # A) Δ
  extend M γ Z     = M
  extend M γ (S x) = γ x
  
  _[_] : Exp (Γ # B) A → Exp Γ B → Exp Γ A
  N [ M ] = subst (extend M `_) N
  
  data _↦_ : Exp · A → Exp · A → Set where
    step-fst   : {M M' : Exp · (prod A₁ A₂)} → (M ↦ M') → (fst M ↦ fst M')
    step-fst-β : {M₁ : Exp · A₁} {M₂ : Exp · A₂} → (fst (pair M₁ M₂) ↦ M₁)
    step-snd   : {M M' : Exp · (prod A₁ A₂)} → (M ↦ M') → (snd M ↦ snd M')
    step-snd-β : {M₁ : Exp · A₁} {M₂ : Exp · A₂} → (snd (pair M₁ M₂) ↦ M₂)
    step-app   : {M₁ M₁' : Exp · (arr A₁ A₂)} {M₂ : Exp · A₁} → (M₁ ↦ M₁') → (app M₁ M₂) ↦ (app M₁' M₂)
    step-app-β : {M₂ : Exp (· # A₁) A₂} {M₁ : Exp · A₁} → (app (lam M₂) M₁) ↦ (M₂ [ M₁ ])
    step-rec   : ∀ {M₀ : Exp · A} {M₁ M M'} → (M ↦ M') → (rec M₀ M₁ M ↦ rec M₀ M₁ M')
    step-rec-β₀ : ∀ {M₀ : Exp · A} {M₁} → (rec M₀ M₁ zero ↦ M₀)
    step-rec-β₁ : ∀ {M₀ : Exp · A} {M₁ M} → (rec M₀ M₁ (suc M) ↦ (M₁ [ rec M₀ M₁ M ]))
  
  data _↦*_ : Exp · A → Exp · A → Set where
    ↦*-refl : {M : Exp · A} → M ↦* M
    ↦*-step : {M M' M'' : Exp · A} → M ↦ M' → M' ↦* M'' → M ↦* M''
  
  ↦*-trans : {M M' M'' : Exp · A} → M ↦* M' → M' ↦* M'' → M ↦* M''
  ↦*-trans ↦*-refl step = step
  ↦*-trans (↦*-step step₁ step₂) step = ↦*-step step₁ (↦*-trans step₂ step)
  
  compatible : {p : Exp · A → Exp · B}
    → ({M M' : Exp · A} → M ↦ M' → p M ↦ p M')
    → {M M' : Exp · A} → M ↦* M' → p M ↦* p M'
  compatible lift ↦*-refl       = ↦*-refl
  compatible lift (↦*-step x s) = ↦*-step (lift x) (compatible lift s)
 



