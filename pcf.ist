(* Forces snd s eagerly. *)
define /filters' {a} p/
/
  ffix (fn filtf s .
          let next filt = filtf in
          bindev t = snd s
          in
            if p (fst s) then
              now (cons 
                     (fst s) 
                     (later (filt t)))
            else
              later (filt t))
//
  intersect i . forall (a : U i) . (a -> bool) -> stream a -> ev (stream a)
/;

inference.
unfold /filters'/.
typecheck.
qed ();



reductions
/
  filters' a p (cons _ h te) -->
    later
      (bindev t = te
       in
         if p h then 
           now (cons a 
                  h
                  (later (filters' a p t)))
         else
           later (filters' a p t)) ;

  unfolding filters'
  unrolling ffix
/;



