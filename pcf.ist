define /stream a/
/
  rec X . a & future (ev X)
//
  intersect i . U i -> U i
/;

inference.
unfold /stream/.
typecheck.
qed ();


define /later_app {a b} ff fx/
/
  let next f = ff in
  let next x = fx in
  next (f x)
//
  intersect (i : level) . forall (a b : U i) . future (a -> b) -> future a -> future b
/;

inference.
introOf /i a b ff fx/.
unfold /later_app/.
typecheck.
qed ();

lemma "later_app_hom"
/
  intersect (i : level) . forall (a b : U i) (f : a -> b) (x : a) . 
    `later_app a b (next f) (next x) = next (f x) : future b
/;

intro /i a b f x/.
unfold /later_app/.
reflexivity.
qed ();


typedef
/
  datatype
    U 0
  of
    ty : type =
    | Nat : ty
    | Arrow : ty -> ty -> ty
/;

typedef
/
  datatype
    U 0
  of
    exp : type =
    | Var : nat -> exp
    (* | Zero : forall (Gamma : ctx) . exp Gamma Nat *)
    | Num : nat -> exp
    | Lam : exp -> exp
    | App : exp -> exp -> exp
    | Fix : exp -> exp
    | Succ : exp -> exp
    | Pred : exp -> exp
    | Ifz : exp -> exp -> exp -> exp
/;

typedef
/
  datatype
    U 0
  of
    has_type : list ty -> exp -> ty -> type =
    | VarTyped : forall (Gamma : list ty) (i : nat) (sigma : ty) . (nth Gamma i = Some sigma : option ty) -> has_type Gamma (Var i) sigma
    | NumTyped : forall (Gamma : list ty) (n : nat) . has_type Gamma (Num n) Nat
    | LamTyped : forall (Gamma : list ty) (sigma tau : ty) (M : exp) . 
        has_type (sigma :: Gamma) M tau -> has_type Gamma (Lam M) (Arrow sigma tau)
    | AppTyped : forall (Gamma : list ty) (sigma tau : ty) (M N : exp) .
        has_type Gamma M (Arrow sigma tau) ->
        has_type Gamma N sigma ->
          has_type Gamma (App M N) tau
    | FixTyped : forall (Gamma : list ty) (sigma : ty) (M : exp) .
        has_type Gamma M (Arrow sigma sigma) ->
          has_type Gamma (Fix M) sigma
    | SuccTyped : forall (Gamma : list ty) (M : exp) .
        has_type Gamma M Nat ->
          has_type Gamma (Succ M) Nat
    | PredTyped : forall (Gamma : list ty) (M : exp) .
        has_type Gamma M Nat ->
          has_type Gamma (Pred M) Nat
    | IfzTyped : forall (Gamma : list ty) (M N P : exp) (sigma : ty) .
        has_type Gamma M Nat ->
        has_type Gamma N sigma ->
        has_type Gamma P sigma ->
          has_type Gamma (Ifz M N P) sigma
/;


typedef
/
  datatype
    U 0
  of
    ctx : type =
    | Empty : ctx
    | Extend : ctx -> ty -> ctx
/;


defineInd /Gamma/
/
  catenate : ctx -> ctx of
  | Empty . Gamma
  | Extend Delta tau . Extend (catenate Delta) tau
//
  ctx -> ctx -> ctx
/;

typedef
/
  datatype
    forall (tau : ty) .
    U 0
  of
    bound : ctx -> type =
    | Z : forall (Gamma : ctx) . bound (Extend Gamma tau)
    | S : forall (sigma : ty) (Gamma : ctx) . bound Gamma -> bound (Extend Gamma sigma)
/;

typedef
/
  datatype
    U 0
  of
    exp : ctx -> ty -> type =
    | Var : forall (Gamma : ctx) (tau : ty) . bound tau Gamma -> exp Gamma tau
    (* | Zero : forall (Gamma : ctx) . exp Gamma Nat *)
    | Num : forall (Gamma : ctx) . nat -> exp Gamma Nat
    | Lam : forall (Gamma : ctx) (sigma tau : ty) . exp (Extend Gamma sigma) tau -> exp Gamma (Arrow sigma tau)
    | App : forall (Gamma : ctx) (sigma tau : ty) . exp Gamma (Arrow sigma tau) -> exp Gamma sigma -> exp Gamma tau
    | Fix : forall (Gamma : ctx) (sigma : ty) . exp Gamma (Arrow sigma sigma) -> exp Gamma sigma
    | Succ : forall (Gamma : ctx) . exp Gamma Nat -> exp Gamma Nat
    | Pred : forall (Gamma : ctx) . exp Gamma Nat -> exp Gamma Nat
    | Ifz : forall (Gamma : ctx) (sigma : ty) . exp Gamma Nat -> exp Gamma sigma -> exp Gamma sigma
/;

define /Subst Gamma Delta/ 
/
  forall (sigma : ty) . bound sigma Gamma -> exp Delta sigma
//
  ctx -> ctx -> U 0
/;

unfold /Subst/.
typecheck.
qed ();

define /Rename Gamma Delta/ 
/
  forall (sigma : ty) . bound sigma Gamma -> bound sigma Delta
//
  ctx -> ctx -> U 0
/;

unfold /Rename/.
typecheck.
qed ();

