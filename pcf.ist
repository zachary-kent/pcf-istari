define /later_app {a b} ff fx/
/
  let next f = ff in
  let next x = fx in
  next (f x)
//
  intersect (i : level) . forall (a b : U i) . future (a -> b) -> future a -> future b
/;

inference.
introOf /i a b ff fx/.
unfold /later_app/.
typecheck.
qed ();

lemma "later_app_hom"
/
  intersect (i : level) . forall (a b : U i) (f : a -> b) (x : a) . 
    `later_app a b (next f) (next x) = next (f x) : future b
/;

intro /i a b f x/.
unfold /later_app/.
reflexivity.
qed ();


typedef
/
  datatype
    intersect (i : level) .
    U i
  of
    ty : type =
    | Nat : ty
    | Arrow : ty -> ty -> ty
/;

typedef
/
  datatype
    intersect (i : level) .
    U i
  of
    term : type =
    | Var : nat -> term
    (* | Zero : forall (Gamma : ctx) . term Gamma Nat *)
    | Num : nat -> term
    | Lam : term -> term
    | App : term -> term -> term
    | Fix : term -> term
    | Succ : term -> term
    | Pred : term -> term
    | Ifz : term -> term -> term -> term
/;

typedef
/
  datatype
    intersect (i : level) .
    U i
  of
    has_type : list ty -> term -> ty -> type =
    | VarTyped : forall (Gamma : list ty) (idx : nat) (sigma : ty) . (nth Gamma idx = Some sigma : option ty) -> has_type Gamma (Var idx) sigma
    | NumTyped : forall (Gamma : list ty) (n : nat) . has_type Gamma (Num n) Nat
    | LamTyped : forall (Gamma : list ty) (sigma tau : ty) (M : term) . 
        has_type (sigma :: Gamma) M tau -> has_type Gamma (Lam M) (Arrow sigma tau)
    | AppTyped : forall (Gamma : list ty) (sigma tau : ty) (M N : term) .
        has_type Gamma M (Arrow sigma tau) ->
        has_type Gamma N sigma ->
          has_type Gamma (App M N) tau
    | FixTyped : forall (Gamma : list ty) (sigma : ty) (M : term) .
        has_type Gamma M (Arrow sigma sigma) ->
          has_type Gamma (Fix M) sigma
    | SuccTyped : forall (Gamma : list ty) (M : term) .
        has_type Gamma M Nat ->
          has_type Gamma (Succ M) Nat
    | PredTyped : forall (Gamma : list ty) (M : term) .
        has_type Gamma M Nat ->
          has_type Gamma (Pred M) Nat
    | IfzTyped : forall (Gamma : list ty) (M N P : term) (sigma : ty) .
        has_type Gamma M Nat ->
        has_type Gamma N sigma ->
        has_type Gamma P sigma ->
          has_type Gamma (Ifz M N P) sigma
/;

defineInd /S enter resolve/
/
  traverse : term -> S -> term of
  | Var i . fn s . resolve s i
  | Num n . fn s . Num n
  | Lam M . fn s . Lam (traverse M (enter s))
  | App M N . fn s . App (traverse M s) (traverse N s)
  | Fix M . fn s . Fix (traverse M s)
  | Succ M . fn s . Succ (traverse M s)
  | Pred M . fn s . Pred (traverse M s)
  | Ifz M N P . fn s . Ifz (traverse M s) (traverse N s) (traverse P s)
//
  intersect (i : level) . forall (S : U i) . (S -> S) -> (S -> nat -> term) -> term -> S -> term
/;


lemma "traverse_var"
/
  intersect (i : level) .
  forall (S : U i) (enter : S -> S) (resolve : S -> nat -> term) (n : nat) (s : S) .
    traverse S enter resolve (Var n) s = resolve s n : term
/;

intro /i S enter resolve n s/.
reduce //.
auto.
qed ();

lemma "traverse_parametric"
/
  intersect (i : level) . 
    forall 
      (S S' : U i) (R : S -> S' -> U i) 
      (enter : S -> S) (enter' : S' -> S') 
      (resolve : S -> nat -> term) (resolve' : S' -> nat -> term)
      (t : term) (s : S) (s' : S') .
        (forall (s : S) (s' : S') . R s s' -> R (enter s) (enter' s')) ->
        (forall (s : S) (s' : S') (n : nat) . R s s' -> resolve s n = resolve' s' n : term) ->
        R s s' ->
        traverse S enter resolve t s = traverse S' enter' resolve' t s' : term
/;

intro /i S S' R enter enter' resolve resolve' t s s' Hrelenter Hagree/.
revert /s s'/.
induction /t/ >> auto.
{
  intro /n s s' Hrel/.
  auto.
}
{
  intro /n s s' Hrel/.
  auto.
}
{
  intro /M IH s s' Heq/.
  auto.
}
(* {
  intro /M IHM N IHN  s s' HRel/.
  compat >> auto.
} *)
{
  intro /M IH s s' Hrel/.
  auto.
}
{
  intro /M IH s s' Hrel/.
  auto.
}
{
  intro /M IHM N IHN P IHP s s' HRel/.
  auto.
}
qed ();

lemma "traverse_compose"
/
  intersect (i : level) .
    forall (S S' : U i) (enter : S -> S) (enter' : S' -> S') (resolve : S -> nat -> term) (resolve' : S' -> nat -> term) (M : term) (s : S) (s' : S') .
      traverse S enter resolve (traverse S' enter' resolve' M s') s
        = traverse (S & S')
            (fn (p : S & S') . (enter (p #1), enter' (p #2)))
            (fn (p : S & S') (n : nat) . traverse S enter resolve (resolve' (p #2) n) (p #1))
            M
            (s, s') : term
/;

intro /i S S' enter enter' resolve resolve' M s s'/.
revert /s s'/.
induction /M/ >> auto.
{
  intro /M IHM N IHN s s'/.
  auto.
}
{
  intro /M IHM N IHN P IHP s s'/.
  auto.
}
qed ();


lemma "traverse_id"
/
  intersect (i : level) .
    forall (S : U i) (R : S -> U i) (enter : S -> S) (resolve : S -> nat -> term) (t : term) (s : S) .
      (forall (s : S) . R s -> R (enter s)) ->
        (forall (s : S) (n : nat) . R s -> resolve s n = Var n : term) ->
          R s ->
          traverse S enter resolve t s = t : term
/;

intro /i S R enter resolve t s Hrelenter Hres/.
revert /s/.
induction /t/ >> auto.
{
  intro /M IH s Hrel/.
  auto.
}
{
  intro /M IHM N IHN s Hrel/.
  auto.
}
{
  intro /M IH s Hrel/.
  auto.
}
{
  intro /M IH s Hrel/.
  auto.
}
{
  intro /M IH s HRel/.
  auto.
}
{
  intro /M IHM N IHN P IHP s Hrel/.
  auto.
}
qed ();

define /pcfSubstT/
/
  (term, Var, traverse)
//
  intersect (i : level) . Subst.SubstType i
/;

unfold /Subst.SubstType/.
unfold /pcfSubstT/.
typecheck.
repeat split >> reduce //.
{ auto. }
{ apply /traverse_parametric/. }
{ apply /traverse_id/. }
{ apply /traverse_compose/. }
qed ();

(* setOpacity /pcfSubstT/ Constant.SOFT; *)

reductions
/
  Subst.term (pcfSubstT) --> term ;
  Subst.var (pcfSubstT) --> Var ;
  unfolding Subst.term Subst.var pcfSubstT
/;

typedef
/ datatype U 0 of
  step : term -> bool -> term -> type =
  | step_app : forall (M M' N : term) (k : bool) . step M k M' -> step (App M N) k (App M' N)
  | step_app_beta : forall (M N : term) . step (App (Lam M) N) false (Subst.subst pcfSubstT (Subst.dot N (Subst.sh 0)) M)
  | step_fix_beta : forall (M : term) . step (Fix M) true (Subst.subst pcfSubstT (Subst.dot M (Subst.sh 0)) M)
  | step_succ_beta : forall (n : nat) . step (Succ (Num n)) false (Num (succ n))
  | step_succ : forall (M N : term) (k : bool) . step M k N -> step (Succ M) k (Succ N)
  | step_pred_beta : forall (n : nat) . step (Pred (Num n)) false (Num (Nat.pred n))
  | step_pred : forall (M N : term) (k : bool) . step M k N -> step (Pred M) k (Pred N)
  | step_ifz_beta_zero : forall (M N : term) . step (Ifz (Num zero) M N) false M
  | step_ifz_beta_succ : forall (M N : term) (n : nat) . step (Ifz (Num (succ n)) M N) false N
  | step_ifz_guard : forall (M M' N P : term) (k : bool) . step M k M' -> step (Ifz M N P) k (Ifz M' N P)
/;


unfold /pcfSubstT/.

define /SubstType i/
/
  exists (term : U i) .
  { var_traverse : (nat -> term) & (intersect (S : U i) . (S -> S) -> (S -> nat -> term) -> S -> term -> term)
  |
    (
      intersect (S : U i) . forall (enter : S -> S) (resolve : S -> nat -> term) (s : S) (n : nat) .
        var_traverse #2 enter resolve s (var_traverse #1 n) = resolve s n : term
    )
    &
    (
      intersect (S S' : U i) . forall (R : S -> S' -> U i) (enter : S -> S) (enter' : S' -> S') (resolve : S -> nat -> term) (resolve' : S' -> nat -> term) (s : S) (s' : S') (t : term) .
      (forall (s : S) (s' : S') . R s s' -> R (enter s) (enter' s'))
      -> (forall (s : S) (s' : S') (n : nat) . R s s' -> resolve s n = resolve' s' n : term)
      -> R s s'
      -> var_traverse #2 enter resolve s t = var_traverse #2 enter' resolve' s' t : term
    )
    &
    (
      intersect (S : U i) . forall (R : S -> U i) (enter : S -> S) (resolve : S -> nat -> term) (s : S) (t : term) .
      (forall (s : S) . R s -> R (enter s))
      -> (forall (s : S) (n : nat) . R s -> resolve s n = var_traverse #1 n : term)
      -> R s
      -> var_traverse #2 enter resolve s t = t : term
    )
    &
    (
      intersect (S S' : U i) . forall (enter : S -> S) (enter' : S' -> S') (resolve : S -> nat -> term) (resolve' : S' -> nat -> term) (s : S) (s' : S') (t : term) .
      var_traverse #2 enter resolve s (var_traverse #2 enter' resolve' s' t)
        = var_traverse #2
          (fn (p : S & S') . (enter (p #1), enter' (p #2)))
          (fn (p : S & S') (n : nat) . var_traverse #2 enter resolve (p #1) (resolve' (p #2) n))
          (s, s') t : term
    )
  }
//
  forall (i : level) . U (1 + i)
/;
introOf /i/.
unfold /SubstType/.
typecheck.
qed();


lemma "traverse_var"
/
  intersect (i : level) . forall (substT : SubstType i) .
  intersect (S : U i) . forall (enter : S -> S) (resolve : S -> nat -> term substT) (s : S) (n : nat) .
      traverse substT enter resolve s (var substT n) = resolve s n : term substT
/;
intro /i [termT [[traverseT varT] Hsub]]/.
unfold /term at all, traverse, var/.
intro /S enter resolve s n/.
reduce /Hsub/.
unhide.
apply /Hsub/.
qed();

lemma "traverse_parametric"
/
  intersect (i : level) . forall (substT : SubstType i) .
  intersect (S S' : U i) . forall (R : S -> S' -> U i) (enter : S -> S) (enter' : S' -> S') (resolve : S -> nat -> term substT) (resolve' : S' -> nat -> term substT) (s : S) (s' : S') (t : term substT) .
  (forall (s : S) (s' : S') . R s s' -> R (enter s) (enter' s'))
  -> (forall (s : S) (s' : S') (n : nat) . R s s' -> resolve s n = resolve' s' n : term substT)
  -> R s s'
  -> traverse substT enter resolve s t = traverse substT enter' resolve' s' t : term substT
/;
intro /i [termT [[traverseT varT] Hsub]]/.
unfold /term at all, traverse at all/.
reduce /Hsub/.
intro /S S' R enter enter' resolve resolve' s s' t H1 H2 H3/.
unhide.
apply /Hsub/ >> auto.
qed();

lemma "traverse_id"
/
  intersect (i : level) . forall (substT : SubstType i) .
  intersect (S : U i) . forall (R : S -> U i) (enter : S -> S) (resolve : S -> nat -> term substT) (s : S) (t : term substT) .
    (forall (s : S) . R s -> R (enter s))
    -> (forall (s : S) (n : nat) . R s -> resolve s n = var substT n : term substT)
    -> R s
    -> traverse substT enter resolve s t = t : term substT
/;
intro /i [termT [[traverseT varT] Hsub]]/.
unfold /term at all, traverse, var/.
intro /S R enter resolve s t H1 H2 H3/.
reduce /Hsub/.
unhide.
apply /Hsub/ >> auto.
qed();

typechecker ();



typedef
/
  datatype
    U 0
  of
    ctx : type =
    | Empty : ctx
    | Extend : ctx -> ty -> ctx
/;


defineInd /Gamma/
/
  catenate : ctx -> ctx of
  | Empty . Gamma
  | Extend Delta tau . Extend (catenate Delta) tau
//
  ctx -> ctx -> ctx
/;

typedef
/
  datatype
    forall (tau : ty) .
    U 0
  of
    bound : ctx -> type =
    | Z : forall (Gamma : ctx) . bound (Extend Gamma tau)
    | S : forall (sigma : ty) (Gamma : ctx) . bound Gamma -> bound (Extend Gamma sigma)
/;

typedef
/
  datatype
    U 0
  of
    term : ctx -> ty -> type =
    | Var : forall (Gamma : ctx) (tau : ty) . bound tau Gamma -> term Gamma tau
    (* | Zero : forall (Gamma : ctx) . term Gamma Nat *)
    | Num : forall (Gamma : ctx) . nat -> term Gamma Nat
    | Lam : forall (Gamma : ctx) (sigma tau : ty) . term (Extend Gamma sigma) tau -> term Gamma (Arrow sigma tau)
    | App : forall (Gamma : ctx) (sigma tau : ty) . term Gamma (Arrow sigma tau) -> term Gamma sigma -> term Gamma tau
    | Fix : forall (Gamma : ctx) (sigma : ty) . term Gamma (Arrow sigma sigma) -> term Gamma sigma
    | Succ : forall (Gamma : ctx) . term Gamma Nat -> term Gamma Nat
    | Pred : forall (Gamma : ctx) . term Gamma Nat -> term Gamma Nat
    | Ifz : forall (Gamma : ctx) (sigma : ty) . term Gamma Nat -> term Gamma sigma -> term Gamma sigma
/;

