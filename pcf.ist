(* lemma "subst_preserves_type"
/
  forall (Gamma : list ty) (M : term) (sigma : ty) .
    has_type Gamma M sigma ->
      forall (sub : Subst.sub pcfSubstT) (Delta : list ty) .
        subst_typed sub Gamma Delta ->
          has_type Delta (Subst.subst pcfSubstT sub M) sigma
/;

intro /Gamma M sigma Hty/.
induction /Hty/.
{
  intro /Gamma idx sigma Hbound sub Delta Hsubty/.
  unfold /subst_typed in Hsubty/.
  auto.
}
{
  intro /Gamma n sub Delta Hsubty/.
  reduce //.
  apply /NumTyped/.
}
{
  intro /Gamma sigma tau M Hty IH sub Delta Hsubty/.
  reduce //.
  apply /LamTyped/.
  apply /IH/.
  unfold /subst_typed/.
  intro /sigma' n Hbound/.
  apply /renaming_preserves_type/.


  intro /Gamma idx sigma Hbound sub Delta Hsubty/.

} *)

define /semantic_renaming {Gamma Delta} sub gamma delta/
/
  forall n m sigma Hbound Hbound' .
    Subst.project pcfSubstT sub n = Var m : term ->
      project sigma Gamma n Hbound gamma = 
        project sigma Delta m Hbound' delta : interp_type sigma
//
  intersect (i : level) .
    forall (Gamma Delta : list ty) .
      Subst.sub pcfSubstT ->
        interp_ctx Gamma ->
          interp_ctx Delta ->
            U i
/;

unfold /semantic_renaming/.
inference.
typecheck.
qed ();

(* lemma "weaken_subst"
/
  forall sub Gamma Delta sigma .
    subst_typed sub Gamma Delta -> *)


lemma "semantic_renaming_eq"
/
  forall (Gamma Delta : list ty) (M : term) (sigma : ty)
    (sub : Subst.sub pcfSubstT) (gamma : interp_ctx Gamma) (delta : interp_ctx Delta)
    (deriv : has_type Gamma M sigma)
    (deriv' : has_type Delta (Subst.subst pcfSubstT sub M) sigma) .
      renaming sub Gamma Delta ->
        semantic_renaming sub gamma delta ->
          interp deriv gamma = interp deriv' delta : interp_type sigma
/;

(* intro /Gamma Delta M sigma sub gamma delta deriv deriv' Hrename Hsemrenaming/. *)
intro /Gamma Delta M sigma sub gamma delta deriv deriv' Hrename Hsemrenaming/.
revert /sub gamma delta deriv' Hrename Hsemrenaming/.
revert /Delta/.
induction /deriv/.
{
  reduce //.
  intro /Gamma idx sigma Hbound Delta sub gamma delta deriv' Hrenaming Hsemrenaming/ >> auto.
  unfold /renaming in Hrenaming/.
  unfold /semantic_renaming in Hsemrenaming/.
  so /Hrenaming _ _ Hbound/ /m Heq Hbound'/.
  (* rewrite /-> Hsemrenaming idx m _ Hbound Hbound' Heq/. *)
  (* setEq /Hty/ /VarTyped Delta m sigma Hbound'/ /_/ /H/. *)
  revert /deriv'/.
  intro /deriv'/.
  rewrite /-> Heq in deriv'/.
  destructThin /deriv'/ /{}/ >> substAll >> auto.
  {
    injection /v5/.
    substAll.
    auto.
  }
  {
    reintro /contra/.
    injection /contra/.
  }
  {
    reintro /contra/.
    injection /contra/.
  }
  {
    reintro /contra/.
    injection /contra/.
  }
  {
    reintro /contra/.
    injection /contra/.
  }
  {
    reintro /contra/.
    injection /contra/.
  }
  {
    reintro /contra/.
    injection /contra/.
  }
}
{
  intro /Gamma n Delta sub gamma delta deriv' Hrename Hsemrename/.
  destructThinCautious /deriv'/ /{}/.
  reduce //.
  auto.
}
{
  intro /Gamma sigma tau M Hty IH Delta sub gamma delta deriv' Hrename Hsemrename/.
  extensionality.
  reintro /V/.
  reduce //.
  destructThinCautious /deriv'/ /{}/.
  substAll >> auto.
  subst /v0/.
  reduce //.
  witness /IH _ _ (V, gamma) (V, delta) v4 __ __/.
  {
    apply /weaken_renaming/.
    auto.
  }
  {
    unfold /semantic_renaming/.
    intro /n m sigma' Hbound Hbound' Hmap/.
    reduce //.
    destruct /n/ / | n/.
    {
      reduce /Hmap/.
      injection /Hmap/.
      subst /m/.
      reduce //.
      destructThinCautious /Hbound/ /{}/.
      destructThinCautious /Hbound'/ /{}/.
      reduce //.
      reflexivity.
      auto.      
    }
    {
      destructThinCautious /Hbound/ /{}/.
      reduce //.
      substAll >> auto.
      reduce /Hmap/.
      destruct /m/ / | m/.
      {
        rewrite /-> project_shift_sub_comm in Hmap/.
        destructThinCautious /Hbound'/ /{}/.
        reduce //.
        substAll >> auto.
        unfold /renaming in Hrename/.
        so /Hrename _ _ v2/ /m Heq Hbound'/.
        revert /Hmap/.
        intro /Hmap/.
        rewrite /-> Heq in Hmap/.
        reduce /Hmap/.
        rewrite /-> Subst.project_sh pcfSubstT in Hmap/.
        reduce /Hmap/.
        injection /Hmap/.
        reintro /Hcontra/.
        injection /Hcontra/.
      }
      {
        destructThinCautious /Hbound'/ /{}/ >> auto.
        reduce //.
        substAll >> auto.
        unfold /semantic_renaming in Hsemrename/.
        apply /Hsemrename/.
        reduce /Hmap/.
        rewrite /-> Subst.shift_sub_eq_compose_sh pcfSubstT in Hmap/.
        rewrite /-> Subst.project_compose in Hmap/.
        unfold /renaming in Hrename/.
        so /Hrename _ _ v2/ /m' Heq Hbound'/.
        substAll.
        revert /Hmap/.
        intro /Hmap/.
        rewrite /-> Heq in Hmap/.
        reduce /Hmap/.
        rewrite /-> Subst.project_sh in Hmap/.
        reduce /Hmap/.
        injection /Hmap/.
        reintro /Hcong/.
        injection /Hcong/.
        substAll.
        assumption.
      }
    }
  }
}
{
  intro /Gamma sigma tau M N HtyM IHM HtyN IHN Delta sub gamma delta Hty/.
  destructThinCautious /Hty/ /{}/.
  reduce //.
  substAll >> auto.
